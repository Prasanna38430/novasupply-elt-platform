# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/

# Secrets and environment — the .env file holds real credentials, never commit it
.env
*.pem
*.key

# Local data: keep the folder structure, ignore the actual files
data/raw/*
!data/raw/.gitkeep
*.duckdb
*.duckdb.wal

# dbt build artefacts and machine-local files
dbt/target/
dbt/dbt_packages/
dbt/logs/
dbt/.user.yml
logs/

# Terraform. State can contain resource metadata and secrets, so it never goes in git;
# .tfvars files hold real values, unlike the committed .example.
**/.terraform/*
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
crash.log
crash.*.log
.terraform.lock.hcl.bak

# Airflow runtime artefacts
airflow/logs/
airflow/plugins/

# OS / editor noise
.DS_Store
Thumbs.db
.vscode/
.idea/
.claude/

# Saved plan files embed the planned state, including variable values.
tfplan
*.tfplan
