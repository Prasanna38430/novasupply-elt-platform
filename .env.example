# NovaSupply configuration template.
# Copy this to `.env` and fill in real values there. The .env file is gitignored
# and must never be committed. Local-first development runs on DuckDB, so none of
# the cloud values below are needed until Phase 7.

# --- Local development ---
RAW_DATA_DIR=data/raw
DUCKDB_PATH=data/novasupply.duckdb

# --- AWS (Phase 7 onward; eu-west-3 is the Paris region) ---
AWS_REGION=eu-west-3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_RAW_BUCKET=

# --- Snowflake trial (Phase 7 onward) ---
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
